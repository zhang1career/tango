# 项目名称，用于部署日志路径 /var/log/<APP_NAME>/app.log，通用机制可复用到其他项目
APP_NAME=tango

# 开发服务器端口（如 3000），不设置则使用 Vite 默认 5173。支持 PORT 或 VITE_PORT
VITE_PORT=3000

# dev: 显示编辑菜单（时间线/地图/人物/事件/物品/元信息）；prod: 仅提供游戏
VITE_APP_MODE=dev

# 内部管理员登录密码（admin 用户），不设置则无法登录
VITE_ADMIN_PASS=

# 登录有效时长（分钟），过期后需重新登录。不设置或无效时默认 120 分钟
VITE_AUTH_EXPIRE_MINUTES=120

# 游戏数据根路径（如 assets/games），相对项目根目录
VITE_GAMES_BASE_PATH=assets/games

# 媒体资源基础 URL（如 CDN），相对路径会拼接此前缀。留空则使用相对路径
VITE_MEDIA_BASE_URL=assets/media

# 剧情生成：自动分页字数范围（每页 300–500 字，按句号/换行边界切分）
VITE_PASSAGE_PAGE_CHARS_MIN=350
VITE_PASSAGE_PAGE_CHARS_MAX=450

# 行为引擎：可用行为列表最大返回数量；同时作为行为交互历史弹窗的初始显示条数
VITE_BEHAVIOR_LIST_LIMIT=3

# 行为交互历史：向上滚动加载更多时，每页加载条数
VITE_BEHAVIOR_HISTORY_PAGE_SIZE=3

# 剧情生成：AI 生成剧情内容（可选）
VITE_AIGC_API_URL=https://api2.aigcbest.top/v1
VITE_AIGC_API_KEY=
